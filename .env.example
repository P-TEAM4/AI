# Riot Games API Key
# Get your API key from https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=1

# Server Configuration
HOST=0.0.0.0
PORT=8000

# ============================================================================
# Backend API 설정 (nexus-gg.kro.kr)
# ============================================================================

# 백엔드 API 사용 여부 (true/false)
# - true: 프로덕션 모드 - 백엔드 API 사용 (매치 조회, 결과 저장)
# - false: 로컬 모드 - Riot API만 사용 (기본값)
USE_BACKEND_API=false

# 백엔드 API 서버 URL (USE_BACKEND_API=true일 때만 사용)
BACKEND_API_BASE_URL=https://nexus-gg.kro.kr

# 백엔드 API 인증 토큰 (필요시 설정)
BACKEND_API_TOKEN=
